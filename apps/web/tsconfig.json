{
  "extends": "@repo/typescript-config/vite.json",
  "include": ["src"],
  "exclude": [
    "src/test",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
